# مسار الـ API
# في وضع التطوير: استعمل "/api" ليتم تمرير الطلبات عبر Vite proxy
#   (يحول الطلبات إلى backend المعرف في vite.config.js).
# في وضع الإنتاج: ضع الرابط الكامل لـ ASP.NET Web API بدون / في النهاية.
VITE_API_URL=/api

# Stripe Publishable Key (للـ Stripe Elements)
# يطابق المفتاح الموجود في backend/GraduationProject.API/appsettings.json
# تحت Stripe.PublishableKey. إذا غيرته في الباك اند يجب أن تغيره هنا أيضاً.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51TNSgaLq1FCKtpTXu4sWPPuuD2bQxIqXTrw5BxOeVEO7JZt7FcWzhPZjtox8GhvAKvASqmuY3VYoTPipRBgowbUV00loU3ShK1

# Google OAuth Client ID (للـ Google Login) — اختياري
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
